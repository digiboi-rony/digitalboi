# ================================================================
# DIGIBOI — Environment Variables
# এই file-এর নাম পরিবর্তন করুন: .env.local
# তারপর নিচের সব value দিয়ে পূরণ করুন
# ================================================================

# SUPABASE (supabase.com থেকে নিন)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT SECRET (যেকোনো random string দিন)
JWT_SECRET=digiboi-super-secret-key-change-this-2025

# CLOUDINARY (cloudinary.com থেকে নিন)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# APP CONFIG
NEXT_PUBLIC_APP_NAME=Digiboi
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
